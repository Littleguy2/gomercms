<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} | {{ settings.site_name }}</title>
<meta name="description" content="{{ description }}">
<link rel="icon" type="image/png" href="{{ settings.logo }}">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<a class="skip-link" href="#main">Skip to content</a>

<header class="site-header">
  <nav class="nav" aria-label="Primary">
    <a class="wordmark" href="/"><img src="{{ settings.logo }}" alt="{{ settings.site_name }} logo" class="logo-mark">GOMER<span>Faith Ministries</span></a>
    <ul class="nav-links" id="nav-links">
      <li><a href="/visit/" {% if nav == "visit" %}aria-current="page"{% endif %}>Visit</a></li>
      <li><a href="/watch/" {% if nav == "watch" %}aria-current="page"{% endif %}>Watch</a></li>
      <li><a href="/ministries/" {% if nav == "ministries" %}aria-current="page"{% endif %}>Ministries</a></li>
      <li><a href="/about/" {% if nav == "about" %}aria-current="page"{% endif %}>About</a></li>
      <li><a href="/contact/" {% if nav == "contact" %}aria-current="page"{% endif %}>Contact</a></li>
    </ul>
    <div class="nav-cta">
      <a class="btn btn-secondary" href="/prayer/">Prayer Request</a>
      <a class="btn btn-primary" href="/give/">Give</a>
      <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="nav-links"></button>
    </div>
  </nav>
</header>

<main id="main">
{{ content | safe }}
</main>

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a class="wordmark" href="/"><img src="{{ settings.logo }}" alt="{{ settings.site_name }} logo" class="logo-mark">GOMER<span>Faith Ministries</span></a>
        <p style="margin-top:16px;max-width:32ch;">{{ settings.tagline }} in Leyton, London, since 2002.</p>
        <div class="social-row">
          <a href="{{ settings.facebook_url }}" aria-label="{{ settings.site_name }} on Facebook">f</a>
          <a href="{{ settings.instagram_url }}" aria-label="{{ settings.site_name }} on Instagram">ig</a>
          <a href="{{ settings.youtube_url }}" aria-label="{{ settings.site_name }} on YouTube">yt</a>
        </div>
      </div>
      <div>
        <h4>Explore</h4>
        <ul>
          <li><a href="/visit/">Visit Us</a></li>
          <li><a href="/watch/">Watch &amp; Sermons</a></li>
          <li><a href="/ministries/">Ministries</a></li>
          <li><a href="/about/">Our Story</a></li>
        </ul>
      </div>
      <div>
        <h4>Connect</h4>
        <ul>
          <li><a href="/prayer/">Prayer Request</a></li>
          <li><a href="/give/">Give</a></li>
          <li><a href="/contact/">Contact</a></li>
          <li><a href="/#newsletter">Newsletter</a></li>
        </ul>
      </div>
      <div>
        <h4>More</h4>
        <ul>
          <li><a href="/visit/#faqs">FAQs</a></li>
          <li><a href="/about/#safeguarding">Safeguarding</a></li>
          <li><a href="#">Privacy Policy</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>{{ settings.copyright_note }}</span>
      <span>{{ settings.address_line1 }}, {{ settings.address_line2 }}</span>
    </div>
  </div>
</footer>

<script src="/js/main.js"></script>

<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", (user) => {
      if (!user) {
        window.netlifyIdentity.on("login", () => {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>
</body>
</html>
